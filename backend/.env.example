# ==========================================
# Web3 Relayer Configuration (.env.example)
# ==========================================

# Port for the Node.js Relayer (Default: 3000)
NODE_RELAYER_PORT=3000

# Web3 Network Configuration (Sepolia Testnet)
# Replace with your actual Infura or Alchemy RPC URL
NETWORK_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# SentinelRegistry Deployed Contract Address
CONTRACT_ADDRESS=0x460DC3605D19B84b76e17Aa59cfe1E2D28479Cc9

# Relayer Wallet Private Key (Without 0x prefix)
# DANGER: Do not commit the actual private key. Ensure this wallet has Sepolia ETH for gas.
RELAYER_PRIVATE_KEY=your_private_key_here

# System Configuration
TRUST_SCORE_THRESHOLD=80
